<UserControl
    x:Class="Clip.Views.DownloadSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Clip.Views">
    <Border Style="{StaticResource GlassCardBorderStyle}" Padding="12">
        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Queue" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="{Binding QueueSummary}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ToggleButton Grid.Column="1"
                              IsChecked="{Binding IsPaused, Mode=TwoWay}"
                              CornerRadius="18"
                              Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <SymbolIcon Symbol="Pause" />
                        <TextBlock Text="Pause" />
                    </StackPanel>
                </ToggleButton>
            </Grid>

            <TabView Grid.Row="1"
                     IsAddTabButtonVisible="False"
                     CanDragTabs="False"
                     TabWidthMode="Equal">
                <TabViewItem Header="Downloads">
                    <views:DownloadList />
                </TabViewItem>
                <TabViewItem Header="History">
                    <views:HistoryView />
                </TabViewItem>
            </TabView>
        </Grid>
    </Border>
</UserControl>
