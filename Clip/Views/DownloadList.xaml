<UserControl
    x:Class="Clip.Views.DownloadList"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ListView ItemsSource="{Binding Downloads}"
              SelectionMode="None"
              Padding="0"
              BorderThickness="0">
        <ListView.ItemTemplate>
            <DataTemplate>
                <Border Style="{StaticResource CompactGlassCardBorderStyle}" Margin="0,0,0,8">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1" />
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Progress, StringFormat='{}{0:0}%'}"
                                       VerticalAlignment="Top"
                                       Foreground="{StaticResource ClipLavenderBrush}" />
                        </Grid>

                        <ProgressBar Grid.Row="1"
                                     Maximum="100"
                                     Value="{Binding Progress}" />

                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="{StaticResource ClipCoralBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                <Button Style="{StaticResource IconButtonStyle}"
                                        Command="{Binding DataContext.CancelCommand, ElementName=Root}"
                                        CommandParameter="{Binding}"
                                        ToolTipService.ToolTip="Cancel">
                                    <SymbolIcon Symbol="Cancel" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}"
                                        Command="{Binding DataContext.RetryCommand, ElementName=Root}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding CanRetry, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTipService.ToolTip="Retry">
                                    <SymbolIcon Symbol="Refresh" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}"
                                        Command="{Binding DataContext.OpenFileCommand, ElementName=Root}"
                                        CommandParameter="{Binding}"
                                        ToolTipService.ToolTip="Open file">
                                    <SymbolIcon Symbol="OpenFile" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}"
                                        Command="{Binding DataContext.OpenFolderCommand, ElementName=Root}"
                                        CommandParameter="{Binding}"
                                        ToolTipService.ToolTip="Open folder">
                                    <SymbolIcon Symbol="Folder" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</UserControl>
