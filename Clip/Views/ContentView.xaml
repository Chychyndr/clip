<UserControl
    x:Class="Clip.Views.ContentView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Clip.Views"
    AllowDrop="True"
    DragOver="OnDragOver"
    Drop="OnDrop">
    <Grid Padding="20,0,20,18" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <views:UpdateBanner />

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="430" />
            </Grid.ColumnDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="12">
                    <views:URLInput />
                    <views:VideoPreview />
                    <views:FormatPicker />
                    <views:ClipRangeView />
                    <views:SaveLocationView />
                    <views:Settings DataContext="{Binding Settings}"
                                    Visibility="{Binding DataContext.ShowSettings, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </ScrollViewer>

            <views:DownloadSection Grid.Column="1" DataContext="{Binding Downloads}" />
        </Grid>

        <views:StatusBarView Grid.Row="2" />
    </Grid>
</UserControl>
