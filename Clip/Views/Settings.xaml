<UserControl
    x:Class="Clip.Views.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource GlassCardBorderStyle}">
        <StackPanel Spacing="10">
            <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="18" />
            <ToggleSwitch Header="Clipboard monitoring"
                          OffContent="Off"
                          OnContent="On"
                          IsOn="{Binding MonitorClipboard, Mode=TwoWay}" />
            <ToggleSwitch Header="Auto-analyze clipboard links"
                          OffContent="Off"
                          OnContent="On"
                          IsOn="{Binding AutoAnalyzeClipboard, Mode=TwoWay}" />
            <ToggleSwitch Header="Hide to tray on close"
                          OffContent="Off"
                          OnContent="On"
                          IsOn="{Binding HideToTrayOnClose, Mode=TwoWay}" />
            <ToggleSwitch Header="Start minimized"
                          OffContent="Off"
                          OnContent="On"
                          IsOn="{Binding StartMinimized, Mode=TwoWay}" />
            <ToggleSwitch Header="Check yt-dlp updates"
                          OffContent="Off"
                          OnContent="On"
                          IsOn="{Binding CheckForYtDlpUpdates, Mode=TwoWay}" />
        </StackPanel>
    </Border>
</UserControl>
