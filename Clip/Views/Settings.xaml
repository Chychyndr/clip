<UserControl
    x:Class="Clip.Views.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource GlassCardBorderStyle}">
        <StackPanel Spacing="14">
            <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="18" />

            <StackPanel Spacing="10">
                <TextBlock Text="General" FontWeight="SemiBold" />
                <ToggleSwitch Header="Clipboard monitoring"
                              OffContent="Off"
                              OnContent="On"
                              IsOn="{Binding Settings.MonitorClipboard, Mode=TwoWay}" />
                <ToggleSwitch Header="Auto-analyze clipboard links"
                              OffContent="Off"
                              OnContent="On"
                              IsOn="{Binding Settings.AutoAnalyzeClipboard, Mode=TwoWay}" />
                <ToggleSwitch Header="Hide to tray on close"
                              OffContent="Off"
                              OnContent="On"
                              IsOn="{Binding Settings.HideToTrayOnClose, Mode=TwoWay}" />
                <ToggleSwitch Header="Start minimized"
                              OffContent="Off"
                              OnContent="On"
                              IsOn="{Binding Settings.StartMinimized, Mode=TwoWay}" />
                <ToggleSwitch Header="Check yt-dlp updates"
                              OffContent="Off"
                              OnContent="On"
                              IsOn="{Binding Settings.CheckForYtDlpUpdates, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock Text="Performance" FontWeight="SemiBold" />
                <Grid ColumnSpacing="12" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ComboBox Header="Concurrent downloads"
                              ItemsSource="{Binding Settings.DownloadConcurrencyOptions}"
                              SelectedItem="{Binding Settings.MaxConcurrentDownloads, Mode=TwoWay}" />
                    <ComboBox Grid.Column="1"
                              Header="Concurrent analysis"
                              ItemsSource="{Binding Settings.AnalysisConcurrencyOptions}"
                              SelectedItem="{Binding Settings.MaxConcurrentMetadataAnalysis, Mode=TwoWay}" />
                    <ComboBox Grid.Row="1"
                              Header="yt-dlp fragments"
                              ItemsSource="{Binding Settings.FragmentOptions}"
                              SelectedItem="{Binding Settings.YtDlpConcurrentFragments, Mode=TwoWay}" />
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Header="ffmpeg jobs"
                             Text="{Binding Settings.MaxConcurrentFfmpegJobs}"
                             IsReadOnly="True" />
                    <ToggleSwitch Grid.Row="2"
                                  Header="Use aria2c for HTTP downloads (experimental)"
                                  OffContent="Off"
                                  OnContent="On"
                                  IsOn="{Binding Settings.UseAria2c, Mode=TwoWay}" />
                    <ToggleSwitch Grid.Row="2"
                                  Grid.Column="1"
                                  Header="Fast TXT batch import"
                                  OffContent="Off"
                                  OnContent="On"
                                  IsOn="{Binding Settings.FastBatchTextImport, Mode=TwoWay}" />
                </Grid>
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock Text="Video Processing" FontWeight="SemiBold" />
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Header="Trim mode"
                              ItemsSource="{Binding Settings.TrimModeOptions}"
                              SelectedItem="{Binding Settings.TrimMode, Mode=TwoWay}" />
                    <ComboBox Grid.Column="1"
                              Header="Compression"
                              ItemsSource="{Binding Settings.CompressionModeOptions}"
                              SelectedItem="{Binding Settings.CompressionMode, Mode=TwoWay}" />
                    <ComboBox Grid.Column="2"
                              Header="Encoder"
                              ItemsSource="{Binding Settings.VideoEncoderOptions}"
                              SelectedItem="{Binding Settings.VideoEncoder, Mode=TwoWay}" />
                </Grid>
                <TextBlock Text="Fast trim uses stream copy and may cut on nearby keyframes. Exact trim re-encodes the selected range."
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock Text="Tools" FontWeight="SemiBold" />
                <Grid ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Button Content="Check yt-dlp"
                            Command="{Binding CheckYtDlpCommand}" />
                    <Button Grid.Column="1"
                            Content="Update yt-dlp"
                            Command="{Binding UpdateYtDlpCommand}" />
                    <Button Grid.Row="1"
                            Content="Check ffmpeg"
                            Command="{Binding CheckFfmpegCommand}" />
                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Content="Open logs folder"
                            Command="{Binding OpenLogsFolderCommand}" />
                    <Button Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Content="Clear metadata cache"
                            Command="{Binding ClearMetadataCacheCommand}" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
