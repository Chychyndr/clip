<Application
    x:Class="Clip.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Clip.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" />

            <Color x:Key="ClipLavender">#8B6DFF</Color>
            <Color x:Key="ClipRosewood">#D3568A</Color>
            <Color x:Key="ClipCoral">#E35F4F</Color>
            <Color x:Key="ClipBronze">#C98942</Color>
            <Color x:Key="ClipSuccess">#2FAF74</Color>

            <SolidColorBrush x:Key="ClipLavenderBrush" Color="{StaticResource ClipLavender}" />
            <SolidColorBrush x:Key="ClipRosewoodBrush" Color="{StaticResource ClipRosewood}" />
            <SolidColorBrush x:Key="ClipCoralBrush" Color="{StaticResource ClipCoral}" />
            <SolidColorBrush x:Key="ClipBronzeBrush" Color="{StaticResource ClipBronze}" />
            <SolidColorBrush x:Key="ClipSuccessBrush" Color="{StaticResource ClipSuccess}" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#33FFFFFF" />
            <SolidColorBrush x:Key="CardBackgroundDarkBrush" Color="#22111111" />
            <SolidColorBrush x:Key="BorderSubtleBrush" Color="#33FFFFFF" />

            <Style x:Key="GlassCardBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            </Style>

            <Style x:Key="CompactGlassCardBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="12" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            </Style>

            <Style x:Key="PillButtonStyle" TargetType="Button">
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="14,7" />
                <Setter Property="MinHeight" Value="36" />
            </Style>

            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style TargetType="ProgressBar">
                <Setter Property="MinHeight" Value="8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
