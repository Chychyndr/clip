<Styles xmlns="https://github.com/avaloniaui">
  <Style Selector="Window">
    <Setter Property="FontFamily" Value="Inter, Segoe UI, San Francisco" />
    <Setter Property="Background" Value="#F6F7F9" />
  </Style>

  <Style Selector="TextBlock.h1">
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#111827" />
  </Style>

  <Style Selector="TextBlock.section">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#111827" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="#D8DEE8" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style Selector="TextBox, ComboBox">
    <Setter Property="CornerRadius" Value="6" />
  </Style>
</Styles>
